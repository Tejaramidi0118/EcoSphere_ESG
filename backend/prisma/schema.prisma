datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Department {
  id                 Int                 @id @default(autoincrement())
  name               String
  code               String              @unique
  head               String
  parentDepartmentId Int?
  parentDepartment   Department?         @relation("DepartmentToDepartment", fields: [parentDepartmentId], references: [id])
  subDepartments     Department[]        @relation("DepartmentToDepartment")
  employeeCount      Int
  status             String              @default("Active") // Active/Inactive
  employees          Employee[]
  carbonTransactions CarbonTransaction[]
  environmentalGoals EnvironmentalGoal[]
  policies           ESGPolicy[]
  audits             Audit[]
  complianceIssues   ComplianceIssue[]
  scores             DepartmentScore[]

  @@index([status])
}

model Employee {
  id                      Int                      @id @default(autoincrement())
  name                    String
  email                   String                   @unique
  passwordHash            String
  role                    String                   @default("employee") // admin / employee
  departmentId            Int
  department              Department               @relation(fields: [departmentId], references: [id])
  xpTotal                 Int                      @default(0)
  createdAt               DateTime                 @default(now())
  policyAcknowledgements  PolicyAcknowledgement[]
  complianceIssuesOwned   ComplianceIssue[]        @relation("EmployeeComplianceIssues")
  participations          EmployeeParticipation[]
  challengeParticipations ChallengeParticipation[]
  badges                  EmployeeBadge[]
  redemptions             RewardRedemption[]
  notifications           Notification[]
}

model Category {
  id         Int           @id @default(autoincrement())
  name       String
  type       String // CSR_ACTIVITY | CHALLENGE
  status     String        @default("Active")
  activities CSRActivity[]
  challenges Challenge[]
}

model EmissionFactor {
  id           Int                 @id @default(autoincrement())
  name         String
  unit         String
  co2PerUnit   Float // in kg CO2e
  source       String              @default("DEFRA 2026")
  transactions CarbonTransaction[]
}

model CarbonTransaction {
  id               Int            @id @default(autoincrement())
  departmentId     Int
  department       Department     @relation(fields: [departmentId], references: [id])
  emissionFactorId Int
  emissionFactor   EmissionFactor @relation(fields: [emissionFactorId], references: [id])
  quantity         Float
  co2Calculated    Float // quantity * co2PerUnit
  sourceType       String // Purchase/Manufacturing/Expense/Fleet/Manual
  date             DateTime

  @@index([departmentId])
  @@index([date])
}

model EnvironmentalGoal {
  id           Int        @id @default(autoincrement())
  name         String
  departmentId Int
  department   Department @relation(fields: [departmentId], references: [id])
  targetCo2    Float // in kg CO2e
  currentCo2   Float      @default(0.0)
  deadline     DateTime
  status       String     @default("Active") // Active/On Track/Completed/Missed

  @@index([departmentId])
  @@index([status])
}

model ESGPolicy {
  id               Int                     @id @default(autoincrement())
  title            String
  description      String
  departmentId     Int?
  department       Department?             @relation(fields: [departmentId], references: [id])
  version          String                  @default("1.0")
  status           String                  @default("Active")
  acknowledgements PolicyAcknowledgement[]
}

model PolicyAcknowledgement {
  id             Int       @id @default(autoincrement())
  policyId       Int
  policy         ESGPolicy @relation(fields: [policyId], references: [id])
  employeeId     Int
  employee       Employee  @relation(fields: [employeeId], references: [id])
  acknowledgedAt DateTime  @default(now())
}

model Audit {
  id               Int               @id @default(autoincrement())
  title            String
  departmentId     Int
  department       Department        @relation(fields: [departmentId], references: [id])
  auditorName      String
  date             DateTime
  findingsSummary  String
  status           String            @default("Scheduled") // Scheduled/Under Review/Completed
  complianceIssues ComplianceIssue[]
}

model ComplianceIssue {
  id              Int        @id @default(autoincrement())
  auditId         Int?
  audit           Audit?     @relation(fields: [auditId], references: [id])
  title           String
  severity        String // Low/Medium/High
  departmentId    Int
  department      Department @relation(fields: [departmentId], references: [id])
  ownerEmployeeId Int
  ownerEmployee   Employee   @relation("EmployeeComplianceIssues", fields: [ownerEmployeeId], references: [id])
  dueDate         DateTime
  status          String     @default("Open") // Open/Resolved
  description     String

  @@index([status])
  @@index([departmentId])
  @@index([dueDate])
}

model CSRActivity {
  id               Int                     @id @default(autoincrement())
  title            String
  categoryId       Int
  category         Category                @relation(fields: [categoryId], references: [id])
  description      String
  evidenceRequired Boolean                 @default(true)
  status           String                  @default("Open") // Open/Closed
  participations   EmployeeParticipation[]
}

model EmployeeParticipation {
  id             Int         @id @default(autoincrement())
  employeeId     Int
  employee       Employee    @relation(fields: [employeeId], references: [id])
  csrActivityId  Int
  csrActivity    CSRActivity @relation(fields: [csrActivityId], references: [id])
  proofUrl       String?
  approvalStatus String      @default("Pending") // Pending/Approved/Rejected
  pointsEarned   Int         @default(0)
  completionDate DateTime    @default(now())

  @@index([approvalStatus])
}

model Challenge {
  id               Int                      @id @default(autoincrement())
  title            String
  categoryId       Int
  category         Category                 @relation(fields: [categoryId], references: [id])
  description      String
  xp               Int
  difficulty       String // Easy/Medium/Hard
  evidenceRequired Boolean                  @default(true)
  deadline         DateTime
  status           String                   @default("Draft") // Draft/Active/Under Review/Completed/Archived
  participations   ChallengeParticipation[]

  @@index([status])
}

model ChallengeParticipation {
  id             Int       @id @default(autoincrement())
  challengeId    Int
  challenge      Challenge @relation(fields: [challengeId], references: [id])
  employeeId     Int
  employee       Employee  @relation(fields: [employeeId], references: [id])
  progressPct    Float     @default(0.0)
  proofUrl       String?
  approvalStatus String    @default("Pending") // Pending/Approved/Rejected
  xpAwarded      Int       @default(0)

  @@index([approvalStatus])
}

model Badge {
  id             Int             @id @default(autoincrement())
  name           String
  description    String
  icon           String
  unlockRule     String // JSON string: {type: 'xp'|'challenges_completed', threshold: N}
  employeeBadges EmployeeBadge[]
}

model EmployeeBadge {
  id         Int      @id @default(autoincrement())
  employeeId Int
  employee   Employee @relation(fields: [employeeId], references: [id])
  badgeId    Int
  badge      Badge    @relation(fields: [badgeId], references: [id])
  awardedAt  DateTime @default(now())
}

model Reward {
  id             Int                @id @default(autoincrement())
  name           String
  description    String
  pointsRequired Int
  stock          Int
  status         String             @default("Active")
  redemptions    RewardRedemption[]
}

model RewardRedemption {
  id             Int      @id @default(autoincrement())
  employeeId     Int
  employee       Employee @relation(fields: [employeeId], references: [id])
  rewardId       Int
  reward         Reward   @relation(fields: [rewardId], references: [id])
  redeemedAt     DateTime @default(now())
  pointsDeducted Int
}

model DepartmentScore {
  id           Int        @id @default(autoincrement())
  departmentId Int
  department   Department @relation(fields: [departmentId], references: [id])
  envScore     Float      @default(0.0)
  socialScore  Float      @default(0.0)
  govScore     Float      @default(0.0)
  totalScore   Float      @default(0.0)
  computedAt   DateTime   @default(now())
}

model Notification {
  id         Int       @id @default(autoincrement())
  employeeId Int? // Nullable means broadcast
  employee   Employee? @relation(fields: [employeeId], references: [id])
  type       String
  message    String
  isRead     Boolean   @default(false)
  createdAt  DateTime  @default(now())
}
